---
---

<section class="px-6 py-24 sm:py-32">
  <div class="mx-auto max-w-5xl">
    <!-- Section header -->
    <div class="text-center">
      <h2 class="text-3xl font-bold sm:text-5xl">gammon.world</h2>
      <p class="mt-4 text-lg text-text-muted">
        Online backgammon with AI opponents — on the web and iOS
      </p>
    </div>

    <!-- Features -->
    <div class="mt-16 grid gap-6 sm:grid-cols-3">
      <div class="rounded-2xl border border-white/5 bg-bg-card p-6">
        <div class="mb-3 text-accent">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="12" height="12" x="2" y="10" rx="2" ry="2"/><path d="m17.92 14 3.5-3.5a2.24 2.24 0 0 0 0-3l-5-4.92a2.24 2.24 0 0 0-3 0L10 6"/><path d="M6 18h.01"/><path d="M10 14h.01"/><path d="M15 6h.01"/><path d="M18 9h.01"/></svg>
        </div>
        <h3 class="font-semibold text-accent">10+ AI Bots</h3>
        <p class="mt-2 text-sm text-text-muted">
          From complete beginner to grandmaster level, powered by GNU Backgammon
        </p>
      </div>
      <div class="rounded-2xl border border-white/5 bg-bg-card p-6">
        <div class="mb-3 text-accent">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v16a2 2 0 0 0 2 2h16"/><path d="m19 9-5 5-4-4-3 3"/></svg>
        </div>
        <h3 class="font-semibold text-accent">Track Your Progress</h3>
        <p class="mt-2 text-sm text-text-muted">
          Detailed stats, rating system, and full game history
        </p>
      </div>
      <div class="rounded-2xl border border-white/5 bg-bg-card p-6">
        <div class="mb-3 text-accent">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
        </div>
        <h3 class="font-semibold text-accent">Play Anywhere</h3>
        <p class="mt-2 text-sm text-text-muted">
          Web browser or iOS app — your progress syncs everywhere
        </p>
      </div>
    </div>

    <!-- Screenshots placeholder -->
    <div class="mt-16 grid gap-4 sm:grid-cols-3">
      <div class="flex aspect-[9/16] items-center justify-center rounded-2xl border border-white/5 bg-bg-card sm:aspect-[9/16]">
        <span class="text-sm text-text-muted">Screenshot 1</span>
      </div>
      <div class="flex aspect-[9/16] items-center justify-center rounded-2xl border border-white/5 bg-bg-card sm:aspect-[9/16]">
        <span class="text-sm text-text-muted">Screenshot 2</span>
      </div>
      <div class="flex aspect-[9/16] items-center justify-center rounded-2xl border border-white/5 bg-bg-card sm:aspect-[9/16]">
        <span class="text-sm text-text-muted">Screenshot 3</span>
      </div>
    </div>

    <!-- CTA buttons -->
    <div class="mt-12 flex flex-wrap items-center justify-center gap-4">
      <a
        href="#"
        class="rounded-xl bg-accent px-8 py-3 font-semibold text-bg transition-colors hover:bg-accent-hover"
      >
        Play on Web — Soon
      </a>
      <a
        href="#"
        class="rounded-xl border border-white/10 px-8 py-3 font-semibold text-text transition-colors hover:border-white/25"
      >
        App Store — Soon
      </a>
    </div>
  </div>
</section>
