---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="404 — AAA Devs">
  <section class="flex min-h-screen flex-col items-center justify-center px-6 text-center">
    <a href="/">
      <img src="/images/logo.svg" alt="AAA Devs" class="mb-12 h-56 w-auto sm:h-72" />
    </a>
    <h1 class="text-6xl font-bold text-accent sm:text-8xl">404</h1>
    <p class="mt-4 text-lg text-text-muted">Page not found</p>
    <a href="/" class="mt-8 rounded-xl bg-accent px-8 py-3 font-semibold text-bg transition-colors hover:bg-accent-hover">
      Back to Home
    </a>
  </section>
</BaseLayout>
