---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Privacy Policy — AAA Devs">
  <div class="mx-auto max-w-3xl px-6 py-24">
    <div class="mb-12 flex justify-center">
      <a href="/">
        <img src="/images/logo.svg" alt="AAA Devs" class="h-56 w-auto sm:h-72" />
      </a>
    </div>
    <h1 class="text-3xl font-bold sm:text-4xl">Privacy Policy</h1>
    <p class="mt-4 text-sm text-text-muted">Last updated: April 2026</p>

    <div class="mt-12 space-y-8 text-text-muted">
      <section>
        <h2 class="mb-3 text-lg font-semibold text-text">Information We Collect</h2>
        <p>When you use our services, we may collect the following information:</p>
        <ul class="mt-2 list-inside list-disc space-y-1">
          <li>Email address (via OAuth sign-in)</li>
          <li>Game statistics and progress</li>
          <li>Device and usage analytics</li>
        </ul>
      </section>

      <section>
        <h2 class="mb-3 text-lg font-semibold text-text">How We Use Your Data</h2>
        <ul class="list-inside list-disc space-y-1">
          <li>To provide and improve our services</li>
          <li>To sync your progress across devices</li>
          <li>To display relevant advertisements (via AdMob)</li>
        </ul>
      </section>

      <section>
        <h2 class="mb-3 text-lg font-semibold text-text">Advertising</h2>
        <p>We use Google AdMob to display ads. AdMob may collect and use your Advertising Identifier (IDFA) to serve personalized ads. You can opt out of personalized advertising in your device settings.</p>
      </section>

      <section>
        <h2 class="mb-3 text-lg font-semibold text-text">Your Rights</h2>
        <ul class="list-inside list-disc space-y-1">
          <li>Request access to your personal data</li>
          <li>Request deletion of your account and data</li>
          <li>Opt out of personalized advertising</li>
        </ul>
      </section>

      <section>
        <h2 class="mb-3 text-lg font-semibold text-text">Contact</h2>
        <p>If you have questions about this policy, contact us at <a href="mailto:ahmlvs@aaadevs.com" class="text-accent hover:text-accent-hover">ahmlvs@aaadevs.com</a>.</p>
      </section>
    </div>

    <div class="mt-16">
      <a href="/" class="text-sm text-text-muted hover:text-text">&larr; Back to home</a>
    </div>
  </div>
</BaseLayout>
